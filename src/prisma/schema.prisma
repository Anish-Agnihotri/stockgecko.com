generator client {
  provider = "prisma-client"
  output   = "../lib/generated/prisma"
}

datasource db {
  provider = "postgresql"
}

// Flat market snapshot entries
model MarketEntry {
  id String @id @default(uuid())

  // Storage batch for O(1) lookup
  batchId String

  // Market identifier
  venue     String
  namespace String
  ticker    String

  // Reference price
  // ---
  // Available options:
  // - Aster: lastPrice, openPrice, highPrice, lowPrice
  // - Binance: lastPrice, openPrice, highPrice, lowPrice
  // - EdgeX: high, low, open, close, lastPrice, indexPrice, oraclePrice, markPrice
  // - Extended: dailyLow, dailyHigh, lastPrice, askPrice, bidPrice, markPrice, indexPrice
  // - Hyperliquid: prevDayPx, oraclePx, markPx, midPx
  // - Lighter: daily_price_low, daily_price_high, last_trade_price
  // - Ostium: bid, mid, ask, lastTradePrice
  // - QFEX: current_mark_price
  // - Vest: openPrice, closePrice, highPrice, lowPrice, markPrice, indexPrice
  // ---
  // Thus, we use:
  // - `lastPrice` where available (7/9)
  // - `midPx` as proxy, reasonably liquid markets (Hyperliquid)
  // - `markPx` (QFEX)
  refPx Decimal

  // Open Interest (dollar notional)
  oi Decimal

  // Volume (dollar notional)
  volume Decimal

  // Max market leverage
  maxLeverage Decimal?

  // Timestamp (write-once)
  createdAt DateTime @default(now())

  @@index([batchId])
  @@index([venue, namespace, ticker, createdAt])
}
