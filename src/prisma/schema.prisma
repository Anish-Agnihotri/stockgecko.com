generator client {
  provider = "prisma-client"
  output   = "../lib/generated/prisma"
}

datasource db {
  provider = "postgresql"
}

// Flat market snapshot entries
model MarketEntry {
  id String @id @default(uuid())

  // Storage batch for O(1) lookup
  batchId String

  // Market identifier
  venue     String
  namespace String
  ticker    String

  // Price reference
  midPx     Decimal
  markPx    Decimal?
  oraclePx  Decimal?
  prevDayPx Decimal?

  // Stats
  oi      Decimal?
  funding Decimal?

  // Volume (in dollars)
  volume Decimal

  // Market reference data
  maxLeverage Decimal?

  // Timestamp record
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([venue, namespace, ticker])
}
